# ── BoM Analyzer Environment Config ───────────────────────────────────────────
# Copy this to .env and fill in values. Never commit .env to git.

# Database
DATABASE_URL=sqlite:///./bom.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://bom_user:yourpassword@localhost:5432/bom_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Currency — leave empty to auto-fetch live rate, or hardcode a fallback
# USD_INR_FALLBACK=83.5

# Scraper settings (optional overrides)
# SCRAPER_MIN_DELAY=1.5
# SCRAPER_MAX_DELAY=3.0
# SCRAPER_MAX_RETRIES=3
# SCRAPER_CACHE_TTL=14400   # 4 hours in seconds

# Celery
# CELERY_CONCURRENCY=4
